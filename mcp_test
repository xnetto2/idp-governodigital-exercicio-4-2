#!/usr/bin/env python3
import json
import subprocess
import sys
import threading
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from pathlib import Path


ROOT = Path(__file__).resolve().parent
CLIENTE = ROOT / "cliente_teste.py"
PYTHON = ROOT / ".venv" / "bin" / "python"
PYTHON_CMD = str(PYTHON) if PYTHON.exists() else sys.executable
HOST = "127.0.0.1"
PORT = 8000


class TarefasHandler(BaseHTTPRequestHandler):
    tarefas = []
    proximo_id = 1

    def _json(self, status, payload):
        body = json.dumps(payload, ensure_ascii=False).encode("utf-8")
        self.send_response(status)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def do_GET(self):
        if self.path == "/tarefas":
            self._json(200, self.tarefas)
            return
        self._json(404, {"erro": "rota nao encontrada"})

    def do_POST(self):
        if self.path != "/tarefas":
            self._json(404, {"erro": "rota nao encontrada"})
            return
        tamanho = int(self.headers.get("Content-Length", "0"))
        payload = json.loads(self.rfile.read(tamanho) or b"{}")
        tarefa = {
            "id": self.proximo_id,
            "titulo": payload.get("titulo", ""),
            "concluida": False,
        }
        type(self).proximo_id += 1
        self.tarefas.append(tarefa)
        self._json(200, tarefa)

    def log_message(self, format, *args):
        return


def iniciar_api_fallback():
    try:
        servidor = ThreadingHTTPServer((HOST, PORT), TarefasHandler)
    except OSError:
        return None
    thread = threading.Thread(target=servidor.serve_forever, daemon=True)
    thread.start()
    return servidor


def main():
    api_fallback = iniciar_api_fallback()
    try:
        proc = subprocess.run(
            [PYTHON_CMD, str(CLIENTE)],
            cwd=str(ROOT),
            capture_output=True,
            text=True,
            timeout=30,
        )
    finally:
        if api_fallback is not None:
            api_fallback.shutdown()

    stdout = (proc.stdout or "").strip()
    try:
        payload = json.loads(stdout)
    except json.JSONDecodeError:
        payload = {
            "ok": False,
            "erro": "cliente_teste.py nao retornou JSON",
            "stdout": stdout,
            "stderr": (proc.stderr or "").strip(),
            "exit_code": proc.returncode,
        }
    else:
        payload = {"ok": proc.returncode == 0, **payload}

    print(json.dumps(payload, ensure_ascii=False, separators=(",", ":")))


if __name__ == "__main__":
    main()
